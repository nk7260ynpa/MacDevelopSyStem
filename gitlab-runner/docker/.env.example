# GitLab Runner 環境變數範本
# 使用方式：複製為同目錄的 .env 後填入實際值。
#   cp .env.example .env
# 注意：.env 含認證權杖，已由根目錄 .gitignore 排除，請勿提交。

# GitLab CI 伺服器網址。
# runner 與 CI job 容器透過 host.docker.internal 連回主機上發佈的 GitLab（8080 埠）。
CI_SERVER_URL=http://host.docker.internal:8080

# Runner 認證權杖（glrt- 開頭）。
# 於 GitLab UI（管理區／群組／專案 → CI/CD → Runners → 新增）建立 Runner 後取得，
# 詳見根目錄 README「GitLab Runner 部署」章節。
RUNNER_TOKEN=glrt-REPLACE_ME

# CI job 未在 .gitlab-ci.yml 指定 image 時，docker executor 使用的預設映像。
RUNNER_DOCKER_IMAGE=alpine:latest

# Runner 描述（顯示於 GitLab Runner 列表）。
RUNNER_DESCRIPTION=mac-local-docker-runner
