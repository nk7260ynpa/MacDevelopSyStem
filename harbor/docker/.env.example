# Harbor Docker Compose 環境變數範本。
#
# 使用方式：
#   cp .env.example .env
#   並依需求調整以下變數後，於 docker-compose.yaml 內以 ${VAR_NAME} 引用。
# 注意：.env 已於專案 .gitignore 內排除，不會提交至版本控制。

# Harbor 版本（image tag）
HARBOR_VERSION=v2.11.0

# 對外 HTTP port（預設 8081，避開 GitLab 之 8080）
HARBOR_HTTP_PORT=8081

# admin 初始密碼（官方預設 Harbor12345，首次登入後請立即修改）
HARBOR_ADMIN_PASSWORD=Harbor12345

# PostgreSQL 密碼
HARBOR_DB_PASSWORD=root123
