# GitLab Docker Compose 環境變數範本。
#
# 使用方式：
#   cp .env.example .env
#   並依需求調整以下變數後，於 docker-compose.yaml 內以 ${VAR_NAME} 引用。
# 注意：.env 已於專案 .gitignore 內排除，不會提交至版本控制。

# 對外 HTTP port（預設 8080）
GITLAB_HTTP_PORT=8080

# 對外 SSH port（預設 2222，避免與 macOS sshd 衝突）
GITLAB_SSH_PORT=2222

# GitLab 外部存取 URL（需與 HTTP port 對應）
GITLAB_EXTERNAL_URL=http://localhost:8080
